{{ 'section-lab-skill-showcase.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --lab-skill-bg: {{ section.settings.background_color }};
    --lab-skill-text: {{ section.settings.text_color }};
    --lab-skill-accent: {{ section.settings.accent_color }};
  }
{%- endstyle -%}

<section class="lab-skill-showcase">
  <div class="lab-skill-showcase__container page-width">
    <div class="lab-skill-showcase__intro">
      {% if section.settings.eyebrow != blank %}
        <p class="lab-skill-showcase__eyebrow">
          {{ section.settings.eyebrow }}
        </p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="lab-skill-showcase__heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="lab-skill-showcase__items">
        {% for block in section.blocks %}
          <div class="lab-skill-showcase__item" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}
              <div class="lab-skill-showcase__icon">
                {{
                  block.settings.icon
                  | image_url: width: 80
                  | image_tag:
                    loading: 'lazy',
                    alt: block.settings.title
                }}
              </div>
            {% endif %}
            {% if block.settings.title != blank %}
              <h3 class="lab-skill-showcase__title">
                {{ block.settings.title }}
              </h3>
            {% endif %}

            {% if block.settings.text != blank %}
              <p class="lab-skill-showcase__text">
                {{ block.settings.text }}
              </p>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Lab skill showcase",
  "tag": "section",
  "class": "section-lab-skill-showcase",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "WHAT'S INSIDE"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "EVERY PRODUCT\nSHOWCASES A CORE\nSHOPIFY SKILL"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "label": "Background",
      "default": "linear-gradient(90deg, #f3faf6 0%, #eef8fb 45%, #ffffff 100%)"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#6aa88f"
    }
  ],
  "blocks": [
    {
      "type": "skill",
      "name": "Skill",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "CLEAN CODE"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Maintainable & scalable Liquid architecture."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lab skill showcase",
    }
  ]
}
{% endschema %}