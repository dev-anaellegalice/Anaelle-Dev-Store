{{ 'lab-collection-header.css' | asset_url | stylesheet_tag }}
<style>
  .section-{{ section.id }} {
    --eyebrow-color: {{ section.settings.eyebrow_color }};
    --heading-color: {{ section.settings.heading_color }};
    --link-color: {{ section.settings.link_color }};
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;
  }
</style>
<section
  class="lab-collection-header section-{{ section.id }}"
  style="

  "
>
  <div class="lab-collection-header__container page-width">
    <div class="lab-collection-header__content">
      {% if section.settings.eyebrow != blank %}
        <p class="lab-collection-header__eyebrow">
          {{ section.settings.eyebrow }}
        </p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="lab-collection-header__heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}
    </div>

    {% if section.settings.link_label != blank and section.settings.link_url != blank %}
      <a href="{{ section.settings.link_url }}" class="lab-collection-header__link">
        {{ section.settings.link_label }}
        <span aria-hidden="true">→</span>
      </a>
    {% endif %}
  </div>
</section>
{% schema %}
{
  "name": "Lab collection header",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore the lab"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "View all products"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL",
      "default": "/collections/all"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow color",
      "default": "#5fa58f"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "Lab collection header"
    }
  ]
}
{% endschema %}